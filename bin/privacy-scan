#!/usr/bin/env php
<?php

declare(strict_types=1);

require dirname(__DIR__, 3) . '/autoload.php';

use Lvmorales1\PrivacyScanner\Commands\ScanCommand;
use Symfony\Component\Console\Application;

$app = new Application('Privacy Scanner');
$app->add(new ScanCommand());
$app->setDefaultCommand('scan', true);
$app->run();